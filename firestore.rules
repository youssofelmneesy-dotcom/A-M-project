rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /bookings/{bookingId} {
      // Authenticated users can create bookings for themselves.
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.serviceId is string
        && request.resource.data.barberId is string
        && request.resource.data.date is string
        && request.resource.data.time is string
        && request.resource.data.status in ['confirmed'];

      // A user can read/update/delete only their own bookings.
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
